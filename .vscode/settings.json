{
  "files.associations": {
    "*.md": "markdown"
  },
  "markdown.validate.enabled": true,
  "editor.wordWrap": "on",
  "editor.rulers": [100],
  "files.exclude": {
    "**/__pycache__": true,
    "**/*.pyc": true
  },
  "search.exclude": {
    "**/node_modules": true,
    "**/.git": true
  },
  "[markdown]": {
    "editor.defaultFormatter": "DavidAnson.vscode-markdownlint",
    "editor.formatOnSave": false,
    "editor.wordWrap": "on",
    "editor.quickSuggestions": {
      "other": true,
      "comments": false,
      "strings": false
    }
  },
  "[python]": {
    "editor.defaultFormatter": "ms-python.black-formatter",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.organizeImports": "explicit"
    }
  },
  "python.analysis.typeCheckingMode": "basic",
  "chat.agent.enabled": true,
  "chat.agentSkillsLocations": {
    "/home/jbl/projects/external-powers/awesome-claude-code-subagents/.github/skills": true,
    "/home/jbl/projects/external-powers/Agent-Skills-for-Context-Engineering/skills": true
  },
  "chat.plugins.enabled": true,
  "chat.pluginLocations": {
    "/home/jbl/projects/external-powers/superpowers": true
  },
  "github.copilot.chat.codeGeneration.instructions": [
    { "file": "AGENTS.md" }
  ]
}
