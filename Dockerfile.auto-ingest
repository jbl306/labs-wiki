FROM python:3.12-slim

WORKDIR /app

COPY scripts/requirements-auto-ingest.txt /app/requirements.txt
RUN pip install --no-cache-dir -r requirements.txt

COPY scripts/auto_ingest.py scripts/watch_raw.py /app/scripts/
COPY scripts/compile_index.py /app/scripts/
COPY templates/ /app/templates/

ENV PROJECT_ROOT=/app
ENV PYTHONUNBUFFERED=1

CMD ["python3", "scripts/watch_raw.py"]
